#import "../functions.typ": *

#content-box[
  #chapter(
    [Common Notions],
    parallel(
      [Κοιναὶ ἔννοιαι.],
      [Common Notions]
    ),
    depth: 2,
  )

  #parallel( 
    [Τὰ τῷ αὐτῷ ἴσα καὶ ἀλλήλοις ἐστὶν ἴσα.],
    [Things equal to the same thing are also equal to one another.],
    n: 1
  )
  #parallel(
    [Καὶ ἐὰν ἴσοις ἴσα προστεθῇ, τὰ ὅλα ἐστὶν ἴσα.],
    [And  if equal things are added to equal things (then) the wholes are equal.],
    n: 2
  )
  #parallel(
    [Καὶ ἐὰν ἀπὸ ἴσων ἴσα ἀφαιρεθῇ, τὰ καταλειπόμενά ἐστιν ἴσα.],
    [And if equal things are subtracted from equal things (then) the remainders are equal.#content-box-note[As an obvious extension of C.N.s~2 \& 3---if equal things are added or subtracted from the two sides of an inequality then  the inequality remains an inequality of the same type.]],
    n: 3
  )
  #parallel(
    [Καὶ τὰ ἐφαρμόζοντα ἐπ᾿ ἀλλήλα ἴσα ἀλλήλοις ἐστίν.],
    [And things coinciding with one another are equal to one another.],
    n: 4
  )
  #parallel(
    [Καὶ τὸ ὅλον τοῦ μέρους μεῖζόν [ἐστιν].],
    [And the whole [is] greater than the part.],
    n: 5
  )
]